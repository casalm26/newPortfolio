{
  "name": "nextjs-business-boilerplate",
  "description": "A modern Next.js business website boilerplate with blog, landing pages, and TypeScript support. Built with Tailwind CSS and shadcn/ui components.",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run appinfo && PORT=6006 NODE_OPTIONS='--no-warnings' next dev",
    "build": "npm run appinfo && next build",
    "serve": "next start",
    "lint": "next lint --fix --dir app --dir components --dir lib",
    "pretty": "prettier --write .",
    "appinfo": "node ./scripts/generateAppInfo.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest run lib/**/*.test.ts components/**/*.test.tsx",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:docker": "BASE_URL=http://app:3000 playwright test",
    "test:all": "npm run test && npm run test:e2e",
    "prepare": "husky"
  },
  "dependencies": {
    "@codemirror/basic-setup": "^0.20.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/react-dom": "^19.1.5",
    "@vercel/analytics": "^1.5.0",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "framer-motion": "^12.15.0",
    "mongoose": "^9.3.2",
    "next": "^15.3.2",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^1.14.0",
    "tailwindcss": "^3.4.16"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.2",
    "eslint-config-prettier": "^10.1.5",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.2",
    "postcss": "^8.5.4",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "react": "^19.1.0",
    "next": "^15.3.2"
  },
  "resolutions": {
    "react": "^19.1.0",
    "next": "^15.3.2"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix --ignore-pattern next-env.d.ts"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
